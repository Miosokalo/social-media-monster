# GitHub fine-grained PAT or classic with repo read (private repos need repo scope).
GITHUB_TOKEN=

# Relative to process cwd; in Docker Compose this is overridden to /app/config/projects.yaml
PROJECTS_CONFIG_PATH=./config/projects.yaml

# Persisted JSON store (tickets, deploy webhook history)
CONTROL_PLANE_DATA_DIR=./data

# Optional: require HMAC-SHA256 signature header `X-Control-Plane-Signature: sha256=<hex>` on webhooks
TICKET_WEBHOOK_SECRET=
DEPLOY_WEBHOOK_SECRET=

# Set to true only on trusted networks — exposes loadavg and memory via GET /api/metrics/host
CONTROL_PLANE_EXPOSE_HOST_METRICS=false

HEALTH_CHECK_TIMEOUT_MS=8000
HEALTH_CACHE_TTL_SECONDS=60

# Comma-separated paths for disk usage (statfs), e.g. / or /,/data
SYSTEM_DISK_PATHS=/

# Host port mapping (used by docker-compose.yml)
CONTROL_PLANE_PORT=3040
